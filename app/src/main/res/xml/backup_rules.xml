<?xml version="1.0" encoding="utf-8"?><!--
   Sample backup rules file; uncomment and customize as necessary.
   See https://developer.android.com/guide/topics/data/autobackup
   for details.
   Note: This file is ignored for devices older than API 31
   See https://developer.android.com/about/versions/12/backup-restore
-->
<full-backup-content>
    <!-- Exclude the encrypted SQLCipher key store. The Android Keystore key that
         decrypts it is not backed up, so restoring this file on a fresh install
         would cause AEADBadTagException on startup. -->
    <exclude domain="file" path="datastore/user_preferences.preferences_pb"/>
</full-backup-content>