<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude the encrypted SQLCipher key store. The Android Keystore key that
             decrypts it is not backed up, so restoring this file on a fresh install
             would cause AEADBadTagException on startup. -->
        <exclude domain="file" path="datastore/user_preferences.preferences_pb"/>
    </cloud-backup>
    <!--
    <device-transfer>
        <include .../>
        <exclude .../>
    </device-transfer>
    -->
</data-extraction-rules>